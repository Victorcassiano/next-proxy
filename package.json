{
  "name": "@victorcassiano/next-proxy",
  "version": "0.0.7",
  "keywords": [
    "next",
    "nextjs",
    "proxy",
    "middleware",
    "routing",
    "redirect"
  ],
  "author": {
    "name": "Victor Cassiano",
    "url": "https://victorcassiano.netlify.app/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Victorcassiano/next-proxy"
  },
  "homepage": "https://github.com/Victorcassiano/next-proxy#readme",
  "bugs": "https://github.com/Victorcassiano/next-proxy/issues",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "types": "./dist/src/index.d.ts",
  "bin": {
    "next-proxy": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "tsd",
    "test:integration": "vitest run tests/integration",
    "test:all": "npm run test && npm run test:types && npm run test:integration"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "execa": "^9.6.1",
    "tsd": "^0.33.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "tsd": {
    "directory": "tests/types"
  }
}
